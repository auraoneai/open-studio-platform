{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AuraOne Open Studio default desktop capability allowlist. Shell and arbitrary HTTP execution are intentionally excluded.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "notification:default",
    "os:default",
    "process:default",
    "clipboard-manager:default",
    "deep-link:default",
    "updater:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    },
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir"
  ]
}
