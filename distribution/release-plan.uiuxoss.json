  "gates": [
    {
      "id": "release-evidence-catalog",
      "command": "node scripts/verify-release-evidence.mjs --require-local-artifacts",
      "required": true
    },
    {
      "id": "distribution-staging",
      "command": "node scripts/verify-distribution-staging.mjs",
      "required": true
    },
    {
      "id": "release-evidence-publishable",
      "command": "node scripts/verify-release-evidence.mjs --publishable --require-local-artifacts",
      "required": true
    },
    {
      "id": "linux-metadata",
      "command": "node scripts/verify-linux-package-matrix.mjs",
      "required": true
    },
    {
      "id": "linux-artifacts",
      "command": "node scripts/verify-linux-artifact-readiness.mjs",
      "required": true
    },
    {
      "id": "winget",
      "command": "node scripts/verify-winget-matrix.mjs",
      "required": true
    },
    {
      "id": "windows-identity",
      "command": "node scripts/verify-windows-package-identity-readiness.mjs",
      "required": true
    },
    {
      "id": "signing-custody",
      "command": "node scripts/verify-signing-custody-readiness.mjs",
      "required": true
    }
  ],
  "publication": {
    "enabled": false,
    "requiresPublishableEvidence": true,
    "destinations": [
      "github-release",
      "homebrew",
      "winget",
      "linux",
      "vscode",
      "updater"
    ]
  }
}
